# ═══════════════════════════════════════════════════════════
# 🎬 DESENHOS ANIMADOS THIAGERA — Configuração de Ambiente
# ═══════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com suas chaves

# ─── Fal.ai (Kling 3.0, Wan 2.7, Flux Dev) ───
FAL_API_KEY=

# ─── Higgsfield (Cinema Studio 3.0, SOUL ID) ───
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=

# ─── ElevenLabs (Vozes PT-BR, Voice Cloning) ───
ELEVENLABS_API_KEY=

# ─── Stable Audio (Música, BGM) ───
STABILITY_API_KEY=

# ─── Claude API (Roteiros) ───
ANTHROPIC_API_KEY=

# ─── YouTube Data API v3 ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=

# ─── Servidor ───
PORT=3001
NODE_ENV=development

# ─── Database ───
DATABASE_PATH=./data/thiagera.db
